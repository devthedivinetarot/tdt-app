{
  "expo": {
    "name": "The Divine Tarot",
    "slug": "divine-tarot",
    "scheme": "divinetarot",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#150b2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thedivinetarot.app"
    },
    "android": {
      "package": "com.thedivinetarot.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#150b2e"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      ["expo-notifications", { "color": "#e9c46a" }],
      ["expo-image-picker", { "photosPermission": "Allow The Divine Tarot to set your profile photo." }]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
